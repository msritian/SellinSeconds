# Supabase (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for auth.admin.createUser (register) and RLS bypass in API routes.
# Create a storage bucket named "listings" in Supabase Dashboard for seller uploads.

# Google Maps (for proximity / distance)
# Enable: Geocoding API, Distance Matrix API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Anthropic (for listing extraction and buyer conversational search; backend only)
# Set ANTHROPIC_API_KEY in backend/.env

# Optional: base URL for server-side API calls (e.g. match_products from /posts)
NEXT_PUBLIC_APP_URL=http://localhost:3000
